<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.2.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.2.0 https://maven.apache.org/xsd/maven-4.2.0.xsd">
    <modelVersion>4.2.0</modelVersion>
    <groupId>io.github.test</groupId>
    <artifactId>jar-with-id</artifactId>
    <version>1.0.0</version>
    <name>jar-with-id</name>
    <dependencies>
        <dependency id="org.slf4j:slf4j-api:2.0.17"/>
        <dependency id="org.example:lib-b:pom:1.0">
            <scope>import</scope>
        </dependency>
        <dependency id="org.example:lib-c:jar:sources:1.0"/>
        <dependency id="org.example:lib-d:1.0">
            <exclusions>
                <exclusion id="org.unwanted:bad-lib"/>
            </exclusions>
        </dependency>
    </dependencies>
</project>
